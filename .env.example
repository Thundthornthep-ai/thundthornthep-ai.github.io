# ============================================================
# Environment variables for scripts/ect-news-notify.py
# ============================================================
# Copy this file to `.env` (in repo root) and fill in real values.
# `.env` is gitignored — NEVER commit real credentials.
#
# All variables are optional: missing ones just disable that channel.
# ============================================================

# Notion integration (https://www.notion.so/my-integrations)
# 1. Create an internal integration → get NOTION_TOKEN (secret_xxx)
# 2. Create a database with columns: Title (title), Date (date),
#    Tier (select), Important (checkbox), Keywords (multi-select),
#    Summary (rich text), PDF URL (url), Pages (number)
# 3. Share the database with the integration → copy database ID from URL
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=0123456789abcdef0123456789abcdef

# Gmail SMTP (https://myaccount.google.com/apppasswords)
# 1. Enable 2-Step Verification on your Google account
# 2. Generate App Password -> use that (NOT your normal password)
# GMAIL_USER=your.name@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_RECIPIENTS=your.name@gmail.com,team@laslegal.co.th
